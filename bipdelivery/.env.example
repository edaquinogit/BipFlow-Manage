# 🛰️ BipFlow Backend Configuration (.env.example)
# Copy this file to .env and update values for your environment

# 🔑 Security Settings
DJANGO_SECRET_KEY=django-insecure-change-this-in-production
DJANGO_DEBUG=True

# 🌐 Public Base URL (used for absolute image URLs when request context is unavailable)
# In production, set this to your actual domain
DJANGO_PUBLIC_BASE_URL=http://127.0.0.1:8000

# 📚 Database (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///db.sqlite3

# 🎯 Frontend Origin (for CORS in production)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
