# BipFlow -- reference for the Render (backend) + Cloudflare Pages (frontend)
# presentation/demo deployment. These are NOT read from a committed file --
# Render env vars are entered in its dashboard (or via render.yaml's
# `sync: false` prompts on first deploy). This file exists so you have one
# place listing every value you'll be asked for, and where each comes from.
#
# This is the split-origin path (chosen because VM signup was blocked).
# The single-domain VM+Nginx path (docker-compose.prod.yml, deploy/
# nginx-vm.conf.example, .env.prod.example) stays in the repo untouched --
# switch back to it later by setting BIPFLOW_CROSS_ORIGIN_COOKIES=False (or
# just unsetting it) and it works exactly as before.

# ------------------------------------------------------------------
# Core Django (Render dashboard -> bipflow-backend -> Environment)
# ------------------------------------------------------------------
DJANGO_ENV=production
DJANGO_SECRET_KEY=                      # render.yaml generates this automatically
# Render assigns this on first deploy (e.g. bipflow-backend.onrender.com);
# add your custom domain here too if you attach one later.
DJANGO_ALLOWED_HOSTS=bipflow-backend.onrender.com
# The Cloudflare Pages frontend URL(s), comma-separated, e.g.:
# https://bipflow.pages.dev,https://seudominio.com
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=
BASE_URL=https://bipflow-backend.onrender.com
FRONTEND_BASE_URL=

# Required for a split-domain deploy -- see BIPFLOW_CROSS_ORIGIN_COOKIES in
# bipdelivery/core/settings.py. render.yaml already sets this to True.
BIPFLOW_CROSS_ORIGIN_COOKIES=True

# ------------------------------------------------------------------
# Database -- Neon (neon.tech), free tier, no card required
# Dashboard -> your project -> Connection Details -> "Pooled connection"
# ------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require
DATABASE_CONN_MAX_AGE=60

# ------------------------------------------------------------------
# Cache -- Upstash (upstash.com), free tier, no card required
# Dashboard -> Redis database -> "Redis Connect" -> rediss:// URL (note the
# double s -- Upstash's free tier is TLS-only, plain redis:// will fail)
# ------------------------------------------------------------------
CACHE_URL=rediss://default:password@xxxx.upstash.io:6379

# ------------------------------------------------------------------
# Cloudflare Turnstile -- same as the VM path, real secret required in prod
# ------------------------------------------------------------------
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------------
# Media -- Cloudflare R2 (same bucket/token as before, nothing new to create)
# ------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bipflow-media
R2_PUBLIC_DOMAIN=

# ------------------------------------------------------------------
# Email (optional for a demo -- console backend just logs, doesn't send)
# ------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@seudominio.com

# ------------------------------------------------------------------
# Frontend build (Cloudflare Pages -> Settings -> Environment variables)
# Project root: bipflow-frontend | Build command: npm run build | Output: dist
# ------------------------------------------------------------------
# VITE_API_URL=https://bipflow-backend.onrender.com/api/
# VITE_TURNSTILE_SITE_KEY=<sua chave publica real do Turnstile>
