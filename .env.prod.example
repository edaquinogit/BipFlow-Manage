# BipFlow -- production .env for docker-compose.prod.yml on the VM.
# Copy to /opt/bipflow/.env on the VM and fill in real values.
# NEVER commit the filled-in file (.env is already in .gitignore).
# Generate strong secrets with: python scripts/generate-secrets.py --env

# ------------------------------------------------------------------
# Core Django
# ------------------------------------------------------------------
DJANGO_ENV=production
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=seudominio.com
CSRF_TRUSTED_ORIGINS=https://seudominio.com
CORS_ALLOWED_ORIGINS=https://seudominio.com
BASE_URL=https://seudominio.com
FRONTEND_BASE_URL=https://seudominio.com

# ------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------
POSTGRES_DB=bipflow
POSTGRES_USER=bipflow
POSTGRES_PASSWORD=
DATABASE_CONN_MAX_AGE=60

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_PASSWORD=

# ------------------------------------------------------------------
# Cloudflare Turnstile (CAPTCHA) -- real secret required in production,
# the published test key is rejected once DJANGO_ENV=production.
# ------------------------------------------------------------------
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------------
# Media storage -- Cloudflare R2 (S3-compatible). All four required;
# settings.py raises ImproperlyConfigured on boot if any is missing.
# ------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bipflow-media
# Optional but recommended: custom domain attached to the R2 bucket via
# Cloudflare (Settings -> Custom Domains). Leave blank to use the raw
# r2.cloudflarestorage.com endpoint instead.
R2_PUBLIC_DOMAIN=media.seudominio.com

# ------------------------------------------------------------------
# Email (transactional / password reset / verification)
# ------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.seuprovedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@seudominio.com

# ------------------------------------------------------------------
# Checkout / WhatsApp
# ------------------------------------------------------------------
WHATSAPP_ORDER_PHONE=
ORDER_DELIVERY_FEE=12.00

# ------------------------------------------------------------------
# Frontend build-time (baked into the image at build, docker-compose.prod.yml)
# ------------------------------------------------------------------
VITE_API_URL=/api/
FRONTEND_PORT=8080

# ------------------------------------------------------------------
# Image tags (only used when pulling from GHCR; the deploy workflow
# overrides IMAGE_TAG with the commit SHA -- leave "latest" for the
# first manual `docker compose up --build`)
# GHCR requires all-lowercase image names -- use lowercase org/repo even if
# the GitHub repository itself has uppercase letters (e.g. BipFlow-Manage).
# ------------------------------------------------------------------
BACKEND_IMAGE=ghcr.io/seu-usuario/seu-repo/backend
FRONTEND_IMAGE=ghcr.io/seu-usuario/seu-repo/frontend
IMAGE_TAG=latest

# ------------------------------------------------------------------
# API throttling -- BipFlow defaults are usually fine in prod, override
# only if you observe false-positive rate limiting.
# ------------------------------------------------------------------
# BIPFLOW_THROTTLE_ANON=20/hour
# BIPFLOW_THROTTLE_USER=100/hour
# BIPFLOW_THROTTLE_AUTH_LOGIN_IDENTITY=5/minute
