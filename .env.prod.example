# BipFlow -- production .env for docker-compose.prod.yml on the VM.
# Copy to /opt/bipflow/.env on the VM and fill in real values.
# NEVER commit the filled-in file (.env is already in .gitignore).
# Generate strong secrets with: python scripts/generate-secrets.py --env

# ------------------------------------------------------------------
# Core Django
# ------------------------------------------------------------------
DJANGO_ENV=production
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=seudominio.com
CSRF_TRUSTED_ORIGINS=https://seudominio.com
CORS_ALLOWED_ORIGINS=https://seudominio.com
BASE_URL=https://seudominio.com
FRONTEND_BASE_URL=https://seudominio.com
# Keep False/unset for single-domain deployments (frontend and backend in the
# same origin). Set True only when frontend and backend run on different
# domains (e.g. Cloudflare Pages + Render) so refresh-token cookies can be
# sent cross-site.
# BIPFLOW_CROSS_ORIGIN_COOKIES=False

# ------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------
POSTGRES_DB=bipflow
POSTGRES_USER=bipflow
POSTGRES_PASSWORD=
DATABASE_CONN_MAX_AGE=60

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_PASSWORD=

# ------------------------------------------------------------------
# Cloudflare Turnstile (CAPTCHA) -- real secret required in production,
# the published test key is rejected once DJANGO_ENV=production.
# ------------------------------------------------------------------
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------------
# Media storage -- Cloudflare R2 (S3-compatible). All four required;
# settings.py raises ImproperlyConfigured on boot if any is missing.
# ------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bipflow-media
# Optional but recommended: custom domain attached to the R2 bucket via
# Cloudflare (Settings -> Custom Domains). Leave BLANK to use the raw
# r2.cloudflarestorage.com endpoint instead -- unlike the other placeholders
# above, this one is NOT required, so the app boots fine either way. If you
# leave the literal example value below unchanged, every product image URL
# will silently point at a domain you don't own instead of failing loudly.
R2_PUBLIC_DOMAIN=media.seudominio.com

# ------------------------------------------------------------------
# Email (transactional / password reset / verification)
# WARNING: none of these four are required by docker-compose.prod.yml's
# :? guards (unlike DJANGO_SECRET_KEY/POSTGRES_PASSWORD/etc above) -- the
# container starts and serves the app fine even if left exactly as below.
# Leaving EMAIL_HOST/EMAIL_HOST_USER/EMAIL_HOST_PASSWORD unfilled doesn't
# fail loudly, it just makes password-reset/verification emails silently
# never arrive. Fill in all four (plus a real DEFAULT_FROM_EMAIL) before
# relying on any email-dependent flow in production.
# ------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.seuprovedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@seudominio.com

# ------------------------------------------------------------------
# Checkout / WhatsApp
# ------------------------------------------------------------------
WHATSAPP_ORDER_PHONE=
ORDER_DELIVERY_FEE=12.00

# ------------------------------------------------------------------
# Frontend build-time (baked into the image at build, docker-compose.prod.yml)
# ------------------------------------------------------------------
VITE_API_URL=/api/
FRONTEND_PORT=8080

# ------------------------------------------------------------------
# Image tags (only used when pulling from GHCR; the deploy workflow
# overrides IMAGE_TAG with the commit SHA -- leave "latest" for the
# first manual `docker compose up --build`)
# GHCR requires all-lowercase image names -- use lowercase org/repo even if
# the GitHub repository itself has uppercase letters (e.g. BipFlow-Manage).
# ------------------------------------------------------------------
BACKEND_IMAGE=ghcr.io/seu-usuario/seu-repo/backend
FRONTEND_IMAGE=ghcr.io/seu-usuario/seu-repo/frontend
IMAGE_TAG=latest

# ------------------------------------------------------------------
# API throttling -- BipFlow defaults are usually fine in prod, override
# only if you observe false-positive rate limiting.
# ------------------------------------------------------------------
# BIPFLOW_THROTTLE_ANON=20/hour
# BIPFLOW_THROTTLE_USER=100/hour
# BIPFLOW_THROTTLE_AUTH_LOGIN_IDENTITY=5/minute
# BIPFLOW_THROTTLE_MFA_VERIFY_IDENTITY=10/minute

# ------------------------------------------------------------------
# HSTS ramp-up plan (only takes effect when DJANGO_ENV=production):
#   1. Deploy with the defaults below (1 hour, no preload) and verify
#      HTTPS/proxy config is solid for a few days.
#   2. Raise SECURE_HSTS_SECONDS to 31536000 (1 year) once confirmed stable.
#   3. Only then consider SECURE_HSTS_PRELOAD=True -- near-irreversible,
#      requires submitting the domain to hstspreload.org.
# ------------------------------------------------------------------
# SECURE_HSTS_SECONDS=3600
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=False

# ------------------------------------------------------------------
# Django admin MFA gate (/admin/login/). Safe to leave at defaults:
# staff who already have MFA configured are always asked for their code;
# DJANGO_ADMIN_MFA_ENFORCED only controls whether staff WITHOUT MFA yet can
# still log in. Before setting it to True, run:
#   docker compose -f docker-compose.prod.yml exec backend \
#     python manage.py list_staff_without_mfa
# and confirm it reports zero accounts -- flipping this on with stragglers
# still unconfigured locks them out of /admin/, including the bootstrap
# admin if they never set up MFA.
# ------------------------------------------------------------------
# BIPFLOW_THROTTLE_ADMIN_LOGIN_IP=5/minute
# BIPFLOW_THROTTLE_ADMIN_LOGIN_IDENTITY=5/minute
# DJANGO_ADMIN_MFA_ENFORCED=False

# ------------------------------------------------------------------
# Optional: dedicated encryption key for TOTP secrets at rest, decoupled
# from DJANGO_SECRET_KEY (see bipdelivery/api/crypto.py's module docstring).
# Safe to leave unset -- existing behavior (key derived from SECRET_KEY) is
# unchanged either way. If you DO set this and any staff already has MFA
# confirmed, run this first or their TOTP secrets become undecryptable:
#   docker compose -f docker-compose.prod.yml exec backend \
#     python manage.py rotate_totp_encryption_key
# Generate a valid value with: python scripts/generate-secrets.py --only TOTP_ENCRYPTION_KEY
# ------------------------------------------------------------------
# TOTP_ENCRYPTION_KEY=
