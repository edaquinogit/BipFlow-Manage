{
  "name": "bipflow-manage-frontend",
  "description": "High-performance Management Ecosystem for Delivery and Logistics",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "Ednaldo <ednal@NotebookNaldo>",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "test:unit": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cypress open",
    "test:e2e:ci": "cypress run",
    "lint": "vue-tsc --noEmit",
    "clean": "rimraf dist node_modules/.vite"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "lucide-vue-next": "^0.471.0",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.27",
    "cypress": "^13.15.0",
    "jsdom": "^25.0.1",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
