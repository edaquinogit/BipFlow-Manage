# 🛰️ BipFlow Frontend Configuration (.env.example)
# Copy this file to .env.local and update values for your environment

# 🌐 API Base URL (Django REST API endpoint)
# The frontend will request data from this URL
VITE_API_URL=http://127.0.0.1:8000/api/

# 🖼️ Backend Origin for Media (optional)
# By default, it's derived from VITE_API_URL (strips /api/ suffix)
# Override if your media server is on a different host than your API
VITE_BACKEND_ORIGIN=http://127.0.0.1:8000

# 📊 Logging Level (optional)
# VITE_LOG_LEVEL=info
