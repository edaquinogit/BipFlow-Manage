# BipFlow Frontend Environment Variables
# Copy this file to .env and update the values

# Django API Base URL (required)
# Relative on purpose -- vite.config.ts proxies /api (and /admin, /media,
# /static) to the Django dev server, so this always resolves against
# whatever origin you used to open the frontend (localhost, 127.0.0.1, or a
# LAN IP when testing from a phone). Also sidesteps the old SameSite=Strict
# cookie mismatch between localhost/127.0.0.1 (they're different sites to a
# browser) since the browser now only ever talks to one origin.
VITE_API_URL=/api/

# Cloudflare Turnstile site key (public, safe to expose) for the conditional
# login CAPTCHA. This is Cloudflare's own published "always passes" test
# key -- replace with a real site key from https://dash.cloudflare.com/ in
# production, matching the real TURNSTILE_SECRET_KEY on the backend.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Optional: Enable debug logging
VITE_DEBUG=true
