# BipFlow Frontend Environment Variables
# Copy this file to .env and update the values

# Django API Base URL (required)
# Must use the same hostname as the one you open the frontend with
# (localhost, not 127.0.0.1) -- the refresh token cookie is SameSite=Strict,
# and browsers treat localhost/127.0.0.1 as different sites, so a mismatch
# silently breaks login persistence across reloads.
VITE_API_URL=http://localhost:8000/api/

# Cloudflare Turnstile site key (public, safe to expose) for the conditional
# login CAPTCHA. This is Cloudflare's own published "always passes" test
# key -- replace with a real site key from https://dash.cloudflare.com/ in
# production, matching the real TURNSTILE_SECRET_KEY on the backend.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Optional: Enable debug logging
VITE_DEBUG=true
