{
  "extends": "@vue/tsconfig/tsconfig.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // 🎯 O Fix Principal: Define a raiz para o mapeamento de paths
    "baseUrl": ".",
    
    // Extra safety for array and object lookups
    "noUncheckedIndexedAccess": true,

    // Path mapping for cleaner imports (NYC Enterprise Standard)
    "paths": {
      "@/*": ["./src/*"]
    },

    // Performance & Incremental Builds
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    
    // Suporte para as novas Macros do Vue (como o defineModel que usamos)
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true
  }
}