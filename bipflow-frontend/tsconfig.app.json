{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "vue",
    
    /* Rigor de Tipagem & Segurança (Padrão Sênior) */
    "strict": true,
    "noUncheckedIndexedAccess": true, //
    "noImplicitAny": true,
    "skipLibCheck": true,
    
    /* Mapeamento de Caminhos (Enterprise Standard) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Performance & Integração */
    "resolveJsonModule": true,
    "types": ["vite/client", "vitest/globals", "node"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "isolatedModules": true,
    "useDefineForClassFields": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "env.d.ts",
    "vite.config.ts",
    "tailwind.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__tests__/*"
  ]
}