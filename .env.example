# BipFlow environment template
# Copy this file to .env, then generate real local secrets:
#   python scripts/generate-secrets.py --env
# Never commit .env.

# Core Django settings
DJANGO_ENV=development
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
# Wildcard so opening the frontend from a phone on the same Wi-Fi (via a LAN
# IP) doesn't 400 -- see the ALLOWED_HOSTS comment in core/settings.py.
DJANGO_ALLOWED_HOSTS=*

# CORS settings (comma-separated URLs)
# In development, sensible defaults are used automatically (localhost:5173, etc.)
# In production, set this to your frontend domains.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Additional production readiness
# DJANGO_SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# CSRF_TRUSTED_ORIGINS=http://localhost:5173

# API throttling / abuse protection
BIPFLOW_THROTTLE_ANON=20/hour
BIPFLOW_THROTTLE_USER=100/hour
BIPFLOW_THROTTLE_PRODUCT_LIST=500/hour
BIPFLOW_THROTTLE_AUTH_IP=10/minute
BIPFLOW_THROTTLE_CHECKOUT_IP=5/minute
BIPFLOW_THROTTLE_CHECKOUT_PHONE=3/hour
BIPFLOW_THROTTLE_BOT_MESSAGE_IP=30/minute
BIPFLOW_THROTTLE_AUTH_LOGIN_IDENTITY=5/minute
BIPFLOW_THROTTLE_AUTH_REGISTER_IDENTITY=3/hour
BIPFLOW_THROTTLE_AUTH_PASSWORD_RESET_IDENTITY=3/hour
BIPFLOW_THROTTLE_AUTH_PASSWORD_RESET_CONFIRM_IDENTITY=5/hour
BIPFLOW_THROTTLE_AUTH_TOKEN_REFRESH_IP=30/minute
BIPFLOW_THROTTLE_AUTH_TOKEN_REFRESH_IDENTITY=10/minute

# Public URLs
BASE_URL=http://127.0.0.1:8000
FRONTEND_BASE_URL=http://127.0.0.1:5173
# Split-origin only (frontend and backend in different domains over HTTPS).
# In local/same-origin setups, keep this unset or False.
# BIPFLOW_CROSS_ORIGIN_COOKIES=False

# Docker Compose infrastructure
DOCKER_PUBLIC_URL=http://localhost:8080
DOCKER_CORS_ALLOWED_ORIGINS=http://localhost:8080
DOCKER_CSRF_TRUSTED_ORIGINS=http://localhost:8080
FRONTEND_PORT=8080
POSTGRES_DB=bipflow
POSTGRES_USER=bipflow
POSTGRES_PASSWORD=
REDIS_PASSWORD=
DATABASE_CONN_MAX_AGE=60
VITE_API_URL=/api/

# Non-compose production examples:
# DATABASE_URL=postgresql://bipflow:URL_ENCODED_POSTGRES_PASSWORD@postgres:5432/bipflow
# CACHE_URL=redis://:URL_ENCODED_REDIS_PASSWORD@redis:6379/1

# Media storage (Cloudflare R2 / S3-compatible). REQUIRED when DJANGO_ENV=production
# -- local disk media does not survive a redeploy. Leave unset in dev/CI.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=bipflow-media
# R2_PUBLIC_DOMAIN=media.example.com

# Optional local demo admin created by the backend entrypoint.
# Leave disabled in production.
# DJANGO_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# DJANGO_BOOTSTRAP_ADMIN_PASSWORD=
# DJANGO_BOOTSTRAP_ADMIN_ROLE=admin

# Checkout / WhatsApp
# Used only as a fallback when the dashboard store WhatsApp is empty.
WHATSAPP_ORDER_PHONE=
ORDER_DELIVERY_FEE=12.00

# Email verification / transactional email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-user
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@bipflow.local
