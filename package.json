{
  "name": "bipflow-manage",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "frontend:dev": "npm --prefix bipflow-frontend run dev",
    "frontend:build": "npm --prefix bipflow-frontend run build",
    "frontend:typecheck": "npm --prefix bipflow-frontend run typecheck",
    "frontend:lint": "npm --prefix bipflow-frontend run lint",
    "frontend:test:unit": "npm --prefix bipflow-frontend run test:unit:run",
    "frontend:test:e2e": "npm --prefix bipflow-frontend run test:e2e:run",
    "prepare": "husky install"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "husky": "^8.0.3",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
